{
    "rewrites": [
        {
            "source": "/baltic-proxy/:path*",
            "destination": "https://api-baltic.transparency-dashboard.eu/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.py"
        }
    ],
    "functions": [
        {
            "api/*.py": {
                "runtime": "vercel-python@0.1.0"
            }
        }
    ]
}